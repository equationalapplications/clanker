{
  "hosting": {
    "site": "clanker",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "clanker",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "*.local"
      ],
      "predeploy": [
        "cd \"$RESOURCE_DIR\" && npx eslint .",
        "cd \"$RESOURCE_DIR\" && node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\" && npx tsc"
      ]
    }
  ]
}