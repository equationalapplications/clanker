{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "types": [
      "expo",
      "expo-router",
      "jest",
      "node"
    ],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "src/*"
      ],
      "expo-router/src/*": [
        "./node_modules/expo-router/build/*"
      ]
    },
    "strict": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "app"
  ],
  "exclude": [
    "functions"
  ]
}