# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase App Check — web (reCAPTCHA Enterprise site key)
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=

# Firebase App Check — web localhost debug token only (set to `auto` or an allowlisted token)
EXPO_PUBLIC_WEB_APP_CHECK_DEBUG_TOKEN=

# Firebase App Check — native debug builds only (never set in EAS production)
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# Google OAuth Configuration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# Facebook OAuth Configuration - TODO
#EXPO_PUBLIC_FACEBOOK_AUTH_APP_ID=

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=   
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat Configuration (native in-app purchases)
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=

# Stripe Configuration (web checkout)
EXPO_PUBLIC_STRIPE_MONTHLY_20_PRICE_ID=
EXPO_PUBLIC_STRIPE_MONTHLY_50_PRICE_ID=
EXPO_PUBLIC_STRIPE_CREDIT_PACK_PRICE_ID=

# Google Services files for local builds
GOOGLE_SERVICE_INFO_PLIST=base64-encoded-iOS-config-file
GOOGLE_SERVICES_JSON=base64-encoded-Android-config-file
