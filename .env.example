# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=
EXPO_PUBLIC_WEB_APP_CHECK_DEBUG_TOKEN=

# Google OAuth Configuration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# Apple OAuth Configuration (web only — Services ID, not App ID)
# Redirect URI: https://<firebase-project-id>.firebaseapp.com/__/auth/handler
EXPO_PUBLIC_APPLE_WEB_CLIENT_ID=
EXPO_PUBLIC_APPLE_WEB_REDIRECT_URI=

# Facebook OAuth Configuration - TODO
#EXPO_PUBLIC_FACEBOOK_AUTH_APP_ID=

# Google Services Files (Base64 Encoded) for local builds
GOOGLE_SERVICES_JSON_BASE64=
GOOGLE_SERVICE_INFO_PLIST_BASE64=

EXPO_PUBLIC_RECAPTCHA_SITE_KEY=

# Stripe Configuration
EXPO_PUBLIC_STRIPE_MONTHLY_20_PRICE_ID=
EXPO_PUBLIC_STRIPE_MONTHLY_50_PRICE_ID=
EXPO_PUBLIC_STRIPE_CREDIT_PACK_PRICE_ID=

# RevenueCat Configuration (native in-app purchases)
# Get these from RevenueCat Dashboard → Project → API Keys
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=

# Dev Sandbox / Local Cloud Agent
# ==================================
# Hybrid mode (recommended): real Firebase login + local Docker cloud-agent.
# Put EXPO_PUBLIC_CLOUD_AGENT_URL in .env.development.local (dev builds only).
# Escalation and Talk tab route to the seeded DEV_CLOUD_CHARACTER_ID in local Postgres.
#
# EXPO_PUBLIC_CLOUD_AGENT_URL=http://<YOUR_LAN_IP>:8080
#
# Legacy mock-auth mode (optional): bypass Firebase Auth entirely.
# Cannot call production generateReply (no real auth token). Prefer hybrid mode.
# EXPO_PUBLIC_USE_MOCK_AUTH=true

# Marketing / public landing pages are static HTML served from public/ (e.g.
# public/real-time-voice/, public/welcome/). To enable their demo videos, edit the
# iframe block in those files directly — no env var dependency, but you still
# need to rerun the web export/deploy flow for Hosting to serve the change.
