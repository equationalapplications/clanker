{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["chrome", "node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src", "test", "../shared/dsl-types.ts", "../shared/constants.ts", "../shared/dsl-schema.ts"],
  "exclude": ["../shared/**/*.test.ts", "../shared/localCloudAgent.ts"]
}
