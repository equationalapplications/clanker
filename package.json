{
  "name": "clanker",
  "version": "28.1.1",
  "main": "expo-router/entry",
  "scripts": {
    "build:prod-a": "node scripts/eas-local-build.js --platform android --profile production",
    "build:dev-a": "node scripts/eas-local-build.js --platform android --profile development",
    "build:prod-i": "node scripts/eas-local-build.js --platform ios --profile production",
    "build:dev-i": "node scripts/eas-local-build.js --platform ios --profile development",
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:clear": "expo start --web -c",
    "web:tunnel": "expo start --web --tunnel",
    "devtools": "react-devtools",
    "release": "semantic-release",
    "prepare": "husky install",
    "commit": "git-cz",
    "format": "prettier --write \"**/*.{js,jsx,json,md,ts,tsx}\"",
    "lint": "npx expo lint --fix",
    "lint:check": "npx expo lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "adb": "adb reverse tcp:8081 tcp:8081",
    "predeploy": "npx expo export --platform web --clear",
    "deploy-hosting": "npm run predeploy && firebase deploy --only hosting",
    "ota": "node -e \"const { spawnSync } = require('child_process'); const easBranch = process.argv[2] || 'production'; const cmd = process.platform === 'win32' ? 'npx.cmd' : 'npx'; const result = spawnSync(cmd, ['--yes', 'eas-cli', 'update', '--auto', '--non-interactive', '--branch', easBranch, '--message', 'OTA update', '--environment', 'production'], { stdio: 'inherit' }); process.exit(result.status ?? 1);\" --",
    "update": "npm run deploy-hosting && npm run ota"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.7",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-firebase/app": "^23.4.1",
    "@react-native-firebase/app-check": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/functions": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "@xstate/react": "^6.1.0",
    "dotenv": "^17.4.2",
    "expo": "^55.0.15",
    "expo-apple-authentication": "~55.0.9",
    "expo-blur": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.27",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.9",
    "expo-modules-core": "~55.0.22",
    "expo-router": "~55.0.8",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.13",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-updates": "~55.0.16",
    "firebase": "^12.12.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-error-boundary": "^2.0.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-chat": "^2.8.1",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-paper": "^5.15.1",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.7.3",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.2",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.9",
    "semantic-release-react-native": "^1.12.2",
    "typescript": "~5.9.2"
  },
  "license": "MIT",
  "expo": {
    "router": {
      "origin": "expo"
    }
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/functions/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  }
}
