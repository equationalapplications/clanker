{
  "name": "clanker",
  "version": "29.19.1",
  "main": "expo-router/entry",
  "scripts": {
    "build:prod-a": "node scripts/eas-local-build.js --platform android --profile production",
    "build:dev-a": "node scripts/eas-local-build.js --platform android --profile development",
    "build:prod-i": "node scripts/eas-local-build.js --platform ios --profile production",
    "build:dev-i": "node scripts/eas-local-build.js --platform ios --profile development",
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:clear": "expo start --web -c",
    "web:tunnel": "expo start --web --tunnel",
    "devtools": "react-devtools",
    "release": "semantic-release",
    "prepare": "husky install",
    "commit": "git-cz",
    "format": "prettier --write \"**/*.{js,jsx,json,md,ts,tsx}\"",
    "lint": "npx expo lint --fix",
    "lint:check": "npx expo lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:generate": "npx expo export --platform web --clear && npm run typecheck",
    "test": "node -e \"const p=require('path');process.env.NODE_OPTIONS=(process.env.NODE_OPTIONS?process.env.NODE_OPTIONS+' ':'')+('--require '+p.resolve('./jest.preload.cjs'));const{spawnSync}=require('child_process');const r=spawnSync(process.platform==='win32'?'jest.cmd':'jest',process.argv.slice(2),{stdio:'inherit',env:process.env});process.exit(r.status??0);\" --",
    "test:watch": "node -e \"const p=require('path');process.env.NODE_OPTIONS=(process.env.NODE_OPTIONS?process.env.NODE_OPTIONS+' ':'')+('--require '+p.resolve('./jest.preload.cjs'));const{spawnSync}=require('child_process');const r=spawnSync(process.platform==='win32'?'jest.cmd':'jest',['--watch',...process.argv.slice(2)],{stdio:'inherit',env:process.env});process.exit(r.status??0);\" --",
    "edge-evals": "node -e \"const p=require('path');process.env.NODE_OPTIONS=(process.env.NODE_OPTIONS?process.env.NODE_OPTIONS+' ':'')+('--require '+p.resolve('./jest.preload.cjs'));const{spawnSync}=require('child_process');const r=spawnSync(process.platform==='win32'?'jest.cmd':'jest',['--config','jest.evals.config.js','--runInBand',...process.argv.slice(2)],{stdio:'inherit',env:process.env});process.exit(r.status??0);\" --",
    "docs:charts": "node scripts/generate-charts.js",
    "adb": "adb reverse tcp:8081 tcp:8081",
    "predeploy": "npx expo export --platform web --clear",
    "deploy-hosting": "npm run predeploy && firebase deploy --only hosting",
    "ota": "node -e \"const { spawnSync } = require('child_process'); const easBranch = process.argv[2] || 'production'; const cmd = process.platform === 'win32' ? 'npx.cmd' : 'npx'; const result = spawnSync(cmd, ['--yes', 'eas-cli', 'update', '--auto', '--non-interactive', '--branch', easBranch, '--message', 'OTA update', '--environment', 'production'], { stdio: 'inherit' }); process.exit(result.status ?? 1);\" --",
    "update": "npm run deploy-hosting && npm run ota"
  },
  "dependencies": {
    "@equationalapplications/core-llm-tools": "^4.10.0",
    "@equationalapplications/expo-llm-wiki": "4.11.0",
    "@expo/metro-runtime": "~56.0.13",
    "@expo/vector-icons": "^15.1.1",
    "@google/genai": "^2.8.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-firebase/app": "^23.4.1",
    "@react-native-firebase/app-check": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/functions": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "@xstate/react": "^6.1.0",
    "dotenv": "^17.4.2",
    "expo": "^56.0.0",
    "expo-apple-authentication": "~56.0.4",
    "expo-asset": "~56.0.15",
    "expo-audio": "~56.0.11",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.16",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.18",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-manipulator": "~56.0.16",
    "expo-image-picker": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-speech-recognition": "~56.0.0",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "firebase": "^12.12.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-error-boundary": "^2.0.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-gifted-chat": "^2.8.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-paper": "^5.15.1",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "wa-sqlite": "^1.0.0",
    "xstate": "^5.30.0",
    "zod-validation-error": "^4.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "better-sqlite3": "^12.9.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.9",
    "semantic-release-react-native": "^1.12.2",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "license": "MIT",
  "expo": {
    "router": {
      "origin": "expo"
    }
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  }
}
