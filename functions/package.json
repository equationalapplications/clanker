{
    "name": "functions",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "build": "rm -rf lib && tsc",
        "test": "NODE_ENV=test npm run build && NODE_ENV=test node --test --test-reporter spec \"lib/**/*.test.js\"",
        "build:watch": "tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions -P clanker-prod",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "22"
    },
    "main": "lib/index.js",
    "type": "module",
    "dependencies": {
        "@google-cloud/cloud-sql-connector": "^1.10.0",
        "@google-cloud/vertexai": "^1.12.0",
        "drizzle-orm": "^0.45.2",
        "firebase-admin": "^13.8.0",
        "firebase-functions": "^7.2.5",
        "pg": "^8.20.0",
        "stripe": "^22.0.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/node": "^22.19.17",
        "@types/pg": "^8.20.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.39.4",
        "eslint-plugin-import": "^2.32.0",
        "firebase-functions-test": "^3.4.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.58.2"
    },
    "private": true
}
