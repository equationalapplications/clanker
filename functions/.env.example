# Cloud SQL
# These are sensitive and must be stored in Firebase Secret Manager (project: <PROJECT_ID>).
# Plaintext values are only used locally via the Cloud SQL proxy.
# CLOUD_SQL_CONNECTION_NAME=<PROJECT_ID>:<REGION>:<INSTANCE_NAME>
# CLOUD_SQL_DB_USER=clanker_app
# CLOUD_SQL_DB_PASS=...
# CLOUD_SQL_DB_NAME=clanker

# Stripe
# - STRIPE_SECRET_KEY is sensitive and must be stored in Firebase Secret Manager.
# - Price IDs and redirect URLs are non-sensitive and configured via .env.clanker-prod.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_MONTHLY_20_PRICE_ID=price_...
STRIPE_MONTHLY_50_PRICE_ID=price_...
STRIPE_CREDIT_PACK_PRICE_ID=price_...
STRIPE_SUCCESS_URL=https://clanker-ai.com/checkout/success
STRIPE_CANCEL_URL=https://clanker-ai.com/checkout/cancel
