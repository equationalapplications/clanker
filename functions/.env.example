# Supabase
# - SUPABASE_SERVICE_ROLE_KEY is sensitive and should be stored in Firebase Secret Manager.
# - SUPABASE_URL is non-sensitive and can be provided via Firebase params or env config.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
# - STRIPE_SECRET_KEY is sensitive and should be stored in Firebase Secret Manager.
# - Price IDs and redirect URLs are non-sensitive and can be provided via Firebase params or env config.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_MONTHLY_20_PRICE_ID=price_...
STRIPE_MONTHLY_50_PRICE_ID=price_...
STRIPE_CREDIT_PACK_PRICE_ID=price_...
STRIPE_SUCCESS_URL=https://yoursbrightly.ai/checkout/success
STRIPE_CANCEL_URL=https://yoursbrightly.ai/checkout/cancel
